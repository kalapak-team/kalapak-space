APP_NAME="Kalapak Code Team"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=kalapak_db
DB_USERNAME=kalapak_user
DB_PASSWORD=kalapak_secret

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost:3000

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@kalapak.dev
MAIL_FROM_NAME="Kalapak Code Team"

# Supabase Storage (S3-compatible)
SUPABASE_ENDPOINT=https://YOUR_PROJECT_ID.supabase.co/storage/v1/s3
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ACCESS_KEY=your-anon-key
SUPABASE_SECRET_KEY=your-service-role-key
SUPABASE_BUCKET=kalapak-assets
SUPABASE_REGION=us-east-1

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=
